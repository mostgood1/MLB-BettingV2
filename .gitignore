.env
.venv/
.venv_x64/
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
*.log
*.err

_tmp_*

# Ignore the data tree by default. Re-include only the canonical frontend inputs.
data/**

# Keep daily artifacts used by the Flask cards, game, and ladder views.
!data/daily/
data/daily/**
!data/daily/daily_summary_*.json
!data/daily/daily_summary_*_profile_bundle.json
!data/daily/daily_summary_*_locked_policy.json
!data/daily/ops/
!data/daily/ops/**
!data/daily/sims/
!data/daily/sims/**
!data/daily/snapshots/
!data/daily/snapshots/*/
!data/daily/snapshots/*/lineups.json
!data/daily/snapshots/*/roster_*.json

# Keep OddsAPI market captures surfaced by the frontend.
!data/market/
data/market/**
!data/market/oddsapi/
!data/market/oddsapi/oddsapi_game_lines_*.json
!data/market/oddsapi/oddsapi_pitcher_props_*.json
!data/market/oddsapi/oddsapi_hitter_props_*.json
data/market/oddsapi/coverage_summary*.json

# Keep season archive manifests, reports, and locked card payloads used by season/history views.
!data/eval/
data/eval/**
!data/eval/seasons/
!data/eval/seasons/*/
!data/eval/seasons/*/season_eval_manifest.json
!data/eval/seasons/*/manifest.json
!data/eval/seasons/*/season_betting_cards_manifest.json
!data/eval/seasons/*/season_betting_cards_retuned_manifest.json
!data/eval/seasons/*/locked_cards/
!data/eval/seasons/*/locked_cards/daily_summary_*_locked_policy.json
!data/eval/seasons/*/locked_cards_retuned/
!data/eval/seasons/*/locked_cards_retuned/daily_summary_*_locked_policy.json
!data/eval/batches/
data/eval/batches/*/
!data/eval/batches/season_2025_regular_sims500_20260316_111829/
!data/eval/batches/season_2025_regular_sims500_20260316_111829/batch_meta.json
!data/eval/batches/season_2025_regular_sims500_20260316_111829/summary.json
!data/eval/batches/season_2025_regular_sims500_20260316_111829/sim_vs_actual_*.json

# Keep archived StatsAPI live feeds used for historical game pages/streams.
!data/raw/
data/raw/**
!data/raw/statsapi/
data/raw/statsapi/**
!data/raw/statsapi/feed_live/
!data/raw/statsapi/feed_live/*/
!data/raw/statsapi/feed_live/*/*/
!data/raw/statsapi/feed_live/*/*/*.json
!data/raw/statsapi/feed_live/*/*/*.json.gz

# Local scratch and cache data should stay untracked even under kept trees.
data/daily/_tmp_*/
data/daily/snapshots/*/team_rosters_raw.json
data/eval/seasons/*/_tmp_*.json
data/eval/seasons/*/_tmp_*.md
data/eval/seasons/*/_partial_*.json
data/eval/seasons/*/_partial_*.md
data/eval/seasons/*/*.md
data/raw/.locks/
data/_tmp_*/
