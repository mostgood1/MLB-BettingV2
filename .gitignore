.env
.venv/
.venv_x64/
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
*.log
*.err

_tmp_*

# Ignore the data tree by default. Re-include only the canonical frontend inputs.
data/**

# Keep daily artifacts used by the Flask cards, game, and ladder views.
!data/daily/
data/daily/**
!data/daily/daily_summary_*.json
!data/daily/daily_summary_*_profile_bundle.json
!data/daily/daily_summary_*_locked_policy.json
!data/daily/top_props/
!data/daily/top_props/*.json
!data/daily/season_frontend/
!data/daily/season_frontend/*.json
!data/daily/ladders/
!data/daily/ladders/*.json
!data/daily/settlements/
!data/daily/settlements/*.json
!data/daily/ops/
!data/daily/ops/**
!data/daily/sims/
!data/daily/sims/**
!data/daily/snapshots/
!data/daily/snapshots/*/
!data/daily/snapshots/*/lineups.json
!data/daily/snapshots/*/roster_*.json

# Ignore optional archive/enrichment datasets to keep repo tracking lean.
data/market/**
!data/eval/
data/eval/**
!data/eval/seasons/
!data/eval/seasons/*/
!data/eval/seasons/*/betting_day_payloads_*/
!data/eval/seasons/*/betting_day_payloads_*/*.json
!data/eval/seasons/*/season_betting_cards*_manifest.json
!data/eval/seasons/*/season_betting_cards*_recap.md
!data/tuning/
data/tuning/**
!data/tuning/so_calibration/
data/tuning/so_calibration/**
!data/tuning/so_calibration/default.json
data/raw/**

# Local scratch and cache data should stay untracked even under kept trees.
data/daily/_tmp_*/
data/daily/snapshots/*/oddsapi_*.json
data/daily/snapshots/*/team_rosters_raw.json
data/_tmp_*/
